(module Sunrom_Tactile_Switch_3x4x2mm_SMD_2-Pin (layer F.Cu) (tedit 68D03052)
  (descr https://www.mouser.com/ds/2/60/RS-282G05A-SM_RT-1159762.pdf)
  (tags "SPST button tactile switch")
  (attr smd)
  (fp_text reference SW1 (at 0 0 -180) (layer F.SilkS)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value SW_Push (at 0 3 -180) (layer F.Fab) hide
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_line (start 2.25 -1.8) (end 2.25 -1.1) (layer F.Fab) (width 0.1))
  (fp_line (start -2.25 -1.8) (end -2.25 -1.1) (layer F.Fab) (width 0.1))
  (fp_line (start -2.25 -1.8) (end 2.25 -1.8) (layer F.Fab) (width 0.1))
  (fp_line (start -2.25 1.8) (end 2.25 1.8) (layer F.Fab) (width 0.1))
  (fp_line (start -1.25 -0.8) (end -1.25 0.8) (layer F.Fab) (width 0.1))
  (fp_line (start 1.25 -0.8) (end 1.25 0.8) (layer F.Fab) (width 0.1))
  (fp_line (start -1.25 -0.8) (end 1.25 -0.8) (layer F.Fab) (width 0.1))
  (fp_line (start -1.25 0.8) (end 1.25 0.8) (layer F.Fab) (width 0.1))
  (fp_line (start 2 1.55) (end -2 1.55) (layer F.SilkS) (width 0.12))
  (fp_line (start 2 -1.55) (end 2 -1.1) (layer F.SilkS) (width 0.12))
  (fp_line (start -2 -1.55) (end 2 -1.55) (layer F.SilkS) (width 0.12))
  (fp_line (start -1.5 1) (end -1.5 -1) (layer F.Fab) (width 0.1))
  (fp_line (start 1.5 1) (end -1.5 1) (layer F.Fab) (width 0.1))
  (fp_line (start 1.5 -1) (end 1.5 1) (layer F.Fab) (width 0.1))
  (fp_line (start -1.5 -1) (end 1.5 -1) (layer F.Fab) (width 0.1))
  (fp_line (start -2.85 -2.05) (end 2.85 -2.05) (layer F.CrtYd) (width 0.05))
  (fp_line (start 2.85 -2.05) (end 2.85 2.05) (layer F.CrtYd) (width 0.05))
  (fp_line (start 2.85 2.05) (end -2.85 2.05) (layer F.CrtYd) (width 0.05))
  (fp_line (start -2.85 2.05) (end -2.85 -2.05) (layer F.CrtYd) (width 0.05))
  (fp_line (start -2 -1.55) (end -2 -1.1) (layer F.SilkS) (width 0.12))
  (fp_line (start -2 1.1) (end -2 1.55) (layer F.SilkS) (width 0.12))
  (fp_line (start -2.25 1.1) (end -2.25 1.8) (layer F.Fab) (width 0.1))
  (fp_line (start 2 1.1) (end 2 1.55) (layer F.SilkS) (width 0.12))
  (fp_line (start 2.25 1.1) (end 2.25 1.8) (layer F.Fab) (width 0.1))
  (fp_text user %R (at 0 -2.6 -180) (layer F.Fab) hide
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (pad 1 smd rect (at -2.2 0) (size 1 1.5) (layers F.Cu F.Paste F.Mask))
  (pad 2 smd rect (at 2.2 0) (size 1 1.5) (layers F.Cu F.Paste F.Mask))
)
